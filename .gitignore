# ─── Environment Variables (KEEP .env pattern but ignore populated files) ─────
# .env is committed but should NOT contain production secrets
# If you have a local override, use .env.local (which IS gitignored)
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── ML Models (large binary files) ──────────────────────────────────────────
model/*.pkl
model/*.h5
model/*.pt
model/*.pth
model/*.onnx
model/*.bin
# Keep metrics.json
!model/metrics.json
!model/.gitkeep

# ─── Datasets (download at runtime via kagglehub) ────────────────────────────
data/
!data/.gitkeep
*.csv
!notebooks/sample_data.csv

